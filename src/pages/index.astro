---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_LOCATION, SITE_TAGLINE, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<p class="kicker">{SITE_LOCATION}</p>
		<h1>{SITE_TITLE}</h1>
		<p class="lede">{SITE_TAGLINE}</p>
		<p class="intro">
			I am currently in Axon's Leadership Development Program. My first rotation was on the Corporate
			AI team, where I went from zero coding background to shipping four production services and a
			bunch of smaller internal tools. My current rotation is as a technical aide to Axon's CEO, which
			means part shadowing, part sounding board, and part building custom software for him and the
			people around him. It is a pretty good seat to learn from, as long as I can keep the ratio of
			strong ideas to aggressively average ones moving in the right direction.
		</p>
		<p class="intro">
			I am especially interested in the future of technology and in how software, AI, and strong
			execution can be applied to real-world problems that are complicated, consequential, and worth
			solving.
		</p>
		<div class="hero-actions">
			<a class="primary" href="/projects">See projects</a>
			<a class="secondary" href="/about">Read about me</a>
		</div>
		<ul class="social-strip" aria-label="Social links">
			{
				SOCIAL_LINKS.map((link) => (
					<li>
						<a href={link.href} target={link.href.startsWith('mailto:') ? undefined : '_blank'}>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</section>

	<section class="grid-section">
		<div class="section-heading">
			<p class="kicker">Featured work</p>
			<h2>Projects are coming next</h2>
			<p class="section-copy">
				I built this site first so it can become the home for the projects, experiments, and case
				studies I publish going forward.
			</p>
		</div>
		<article class="card empty-card">
			<p class="card-topline">In progress</p>
			<h3>First public projects are still being built.</h3>
			<p>
				That is intentional. Instead of filling this page with weak placeholders, I would rather ship
				real work and document it properly once it is worth showing.
			</p>
		</article>
	</section>

	<section class="split-section">
		<div class="section-heading">
			<p class="kicker">Writing</p>
			<h2>Writing will live here when it is ready</h2>
			<p class="section-copy">
				I am keeping the structure in place for future posts on projects, AI, technology, career
				development, and anything else worth making more permanent than a passing social post.
			</p>
		</div>
		<div class="post-list">
			{
				posts.length > 0 ? (
					posts.map((post) => (
						<a class="card post-card" href={`/blog/${post.id}/`}>
							<p class="card-topline">
								{post.data.pubDate.toLocaleDateString('en-US', {
									month: 'short',
									day: 'numeric',
									year: 'numeric',
								})}
							</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))
				) : (
					<article class="card empty-card">
						<p class="card-topline">No posts yet</p>
						<h3>The blog is set up and ready.</h3>
						<p>
							When I have something useful to say, it will show up here. Until then, the structure is
							in place without fake content.
						</p>
					</article>
				)
			}
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		padding: 5rem 0 4rem;
	}
	.kicker {
		margin-bottom: 0.8rem;
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}
	.hero h1 {
		max-width: 12ch;
		font-size: clamp(3.8rem, 11vw, 8rem);
		line-height: 0.92;
		margin-bottom: 1rem;
	}
	.lede {
		max-width: 34rem;
		font-size: clamp(1.15rem, 2vw, 1.5rem);
		color: rgb(var(--ink));
	}
	.intro,
	.section-copy {
		max-width: 38rem;
		color: rgb(var(--muted));
	}
	.hero-actions,
	.social-strip {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}
	.social-strip {
		list-style: none;
		padding: 0;
	}
	.primary,
	.secondary,
	.social-strip a,
	.text-link {
		text-decoration: none;
	}
	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		padding: 0.8rem 1.15rem;
		border-radius: 999px;
		font-weight: 700;
	}
	.primary {
		background: rgb(var(--ink));
		color: rgb(var(--paper-rgb));
	}
	.secondary {
		border: 1px solid rgba(var(--border), 0.9);
		color: rgb(var(--ink));
	}
	.social-strip a {
		color: rgb(var(--muted));
	}
	.grid-section,
	.split-section {
		padding: 2rem 0 4rem;
	}
	.section-heading h2 {
		margin-bottom: 0.75rem;
	}
	.post-list {
		display: grid;
		gap: 1rem;
	}
	.split-section {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
		gap: 2rem;
		align-items: start;
	}
	.card {
		padding: 1.35rem;
		border-radius: 24px;
		border: 1px solid rgba(var(--border), 0.9);
		background: rgba(var(--paper-rgb), 0.72);
	}
	.card-topline {
		margin-bottom: 0.6rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}
	.project-card h3,
	.post-card h3 {
		margin-bottom: 0.75rem;
	}
	.empty-card {
		max-width: 44rem;
	}
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		padding: 0;
		margin: 1rem 0;
	}
	.tag-list li {
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		background: rgba(var(--accent-soft), 0.95);
		font-size: 0.85rem;
	}
	.text-link {
		color: rgb(var(--ink));
		font-weight: 700;
	}
	.post-card {
		color: inherit;
	}
	@media (max-width: 900px) {
		.split-section {
			grid-template-columns: 1fr;
		}
	}
</style>
