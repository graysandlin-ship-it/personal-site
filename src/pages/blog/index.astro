---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<section class="page-head">
		<p class="eyebrow">Blog</p>
		<h1>A place for future notes, essays, and project writeups.</h1>
		<p>
			The structure is here, but I am not forcing filler posts just to make the page look populated.
			When there is something worth saying, it will live here.
		</p>
	</section>

	<section class="post-grid">
		{
			posts
				.filter((post) => !post.data.draft)
				.map((post) => (
					<a class="post-card" href={`/blog/${post.id}/`}>
						<p class="date"><FormattedDate date={post.data.pubDate} /></p>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
						{post.data.tags.length > 0 && (
							<ul class="tag-list" aria-label={`${post.data.title} tags`}>
								{post.data.tags.map((tag) => <li>{tag}</li>)}
							</ul>
						)}
					</a>
				))
		}
		{
			posts.filter((post) => !post.data.draft).length === 0 && (
				<article class="post-card empty-state">
					<p class="date">No posts yet</p>
					<h2>The blog is ready when I am.</h2>
					<p>
						This section will eventually hold project writeups, thoughts on AI and tech, and notes
						from whatever I am learning or building.
					</p>
				</article>
			)
		}
	</section>
</BaseLayout>

<style>
	.page-head {
		max-width: 44rem;
		padding: 4rem 0 2rem;
	}
	.eyebrow {
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}
	.page-head h1 {
		font-size: clamp(2.4rem, 7vw, 5rem);
		margin-bottom: 1rem;
	}
	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		padding-bottom: 3rem;
	}
	.post-card {
		display: block;
		padding: 1.35rem;
		border-radius: 24px;
		border: 1px solid rgba(var(--border), 0.9);
		background: rgba(var(--paper-rgb), 0.72);
		color: inherit;
		text-decoration: none;
	}
	.empty-state {
		max-width: 44rem;
	}
	.date {
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--muted));
	}
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
	}
	.tag-list li {
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		background: rgba(var(--accent-soft), 0.95);
		font-size: 0.85rem;
	}
	@media (max-width: 900px) {
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
